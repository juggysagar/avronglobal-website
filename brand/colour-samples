<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Avron Global — Business Card System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Crimson+Text:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --navy: #001D3D;
            --forest: #2C4A3B;
            --burgundy: #722F37;
            --brass: #B8956B;
            --sand: #F5F1EB;
            --cream: #FAF8F5;
            --charcoal: #2C2C2C;
            
            --card-w: 85mm;
            --card-h: 55mm;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Crimson Text', Georgia, serif;
            background: #e8e8e8;
            padding: 40px;
            display: flex;
            flex-direction: column;
            gap: 60px;
        }
        
        .card-set {
            display: flex;
            gap: 40px;
            align-items: flex-start;
        }
        
        .card-pair {
            display: flex;
            gap: 20px;
        }
        
        /* Business Card Base */
        .card {
            width: var(--card-w);
            height: var(--card-h);
            position: relative;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            overflow: hidden;
        }
        
        /* FRONT STYLES */
        .card-front {
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .monogram-container {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .brass-border {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            background: var(--brass);
        }
        
        .navy-front .brass-border { width: 3mm; }
        .forest-front .brass-border { width: 3mm; }
        .burgundy-front .brass-border { width: 4mm; }
        
        .ag-mark {
            font-family: 'Cinzel', serif;
            font-weight: 700;
            font-size: 28px;
            letter-spacing: 0.12em;
            color: var(--sand);
        }
        
        /* Color Variants */
        .navy-front { background: var(--navy); }
        .forest-front { background: var(--forest); }
        .burgundy-front { background: var(--burgundy); }
        
        /* BACK STYLES */
        .card-back {
            padding: 8mm 6mm 6mm 8mm;
            display: flex;
            flex-direction: column;
        }
        
        .navy-back { background: var(--sand); }
        .forest-back { background: var(--sand); }
        .burgundy-back { background: var(--cream); }
        
        .back-content {
            height: 100%;
            display: flex;
            flex-direction: column;
            position: relative;
        }
        
        .name {
            font-family: 'Cinzel', serif;
            font-size: 14pt;
            font-weight: 700;
            margin-bottom: 2mm;
            letter-spacing: 0.02em;
        }
        
        .navy-back .name { color: var(--navy); }
        .forest-back .name { color: var(--forest); }
        .burgundy-back .name { color: var(--burgundy); }
        
        .title {
            font-family: 'Inter', sans-serif;
            font-size: 9pt;
            font-weight: 400;
            color: var(--charcoal);
            margin-bottom: 6mm;
        }
        
        .company {
            font-family: 'Cinzel', serif;
            font-size: 11pt;
            font-weight: 600;
            margin-bottom: 1mm;
        }
        
        .navy-back .company { color: var(--navy); }
        .forest-back .company { color: var(--forest); }
        .burgundy-back .company { color: var(--burgundy); }
        
        .tagline {
            font-family: 'Inter', sans-serif;
            font-size: 7pt;
            font-weight: 500;
            color: var(--brass);
            text-transform: uppercase;
            letter-spacing: 0.2em;
            margin-bottom: 4mm;
        }
        
        .special-line {
            font-family: 'Inter', sans-serif;
            font-size: 7pt;
            font-style: italic;
            margin-bottom: 3mm;
        }
        
        .navy-back .special-line { display: none; }
        .forest-back .special-line { color: var(--forest); }
        .burgundy-back .special-line { 
            color: var(--burgundy); 
            font-style: normal;
            font-weight: 500;
        }
        
        .contact {
            font-family: 'Inter', sans-serif;
            font-size: 8pt;
            font-weight: 400;
            color: var(--charcoal);
            line-height: 1.5;
            margin-top: auto;
            margin-bottom: 3mm;
        }
        
        .bottom-rule {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--brass);
        }
        
        .navy-back .bottom-rule { height: 0.5pt; }
        .forest-back .bottom-rule { height: 0.5pt; }
        .burgundy-back .bottom-rule { height: 1pt; }
        
        /* Labels */
        .set-label {
            font-family: 'Inter', sans-serif;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--charcoal);
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 2px solid var(--brass);
            width: fit-content;
        }
        
        .mode-description {
            font-family: 'Crimson Text', serif;
            font-size: 13px;
            color: #666;
            font-style: italic;
            margin-top: 8px;
            max-width: 400px;
        }
    </style>
</head>
<body>

